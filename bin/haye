#!/usr/bin/env python3
import json, os, sys, re, subprocess
from pathlib import Path

CORE_FILES=['HAYE.md','index.md','current.md','next.md','changelog.md','health.md']
DIRS=['00-system','01-project','01-prompts','02-decisions','03-bugs/open','03-bugs/solved','03-bugs/recurring','04-tasks','05-sessions','06-prompts','07-checklists','08-raw/claude-sessions','08-raw/terminal-logs','08-raw/screenshots','08-raw/old-prompts','08-raw/docs','09-context-packs','10-reviews','11-metrics','12-risks','99-archive']
DEFAULT_CONFIG={'sourcePath':'.','riskLevel':'medium','defaultWorkflow':'memory-first','sessionCloseRequired':True,'rawReadPolicy':'explicit-only'}
class ConfigError(Exception): pass

def cwd(): return Path.cwd()
def config_path(): return cwd()/'.hayeos.json'
def load_config():
    p=config_path()
    if p.exists():
        try:
            cfg=json.loads(p.read_text())
            if isinstance(cfg, dict): return {**DEFAULT_CONFIG, **cfg}
            raise ConfigError('Invalid .hayeos.json: root must be an object')
        except json.JSONDecodeError as e:
            raise ConfigError(f'Invalid .hayeos.json: {e}')
    return {}

def source_path():
    cfg=load_config(); sp=cfg.get('sourcePath') or cfg.get('source_path') or '.'
    p=Path(sp)
    return (cwd()/p).resolve() if not p.is_absolute() else p
def memory_path():
    cfg=load_config(); mp=cfg.get('memoryPath') or cfg.get('memory_path')
    if mp: return (cwd()/mp).resolve() if not Path(mp).is_absolute() else Path(mp)
    for cand in cwd().glob('*_obs'):
        if cand.is_dir(): return cand.resolve()
    return None

def plugin_root():
    return Path(__file__).resolve().parent.parent

def ensure_project_memory_target(p):
    target=Path(p).resolve()
    root=plugin_root().resolve()
    try:
        target.relative_to(root)
        print("Bu dosya plugin klasörüne yazılmaya çalışılıyor. Proje vault'u kullanılmalı.", file=sys.stderr)
        return False
    except ValueError:
        return True

def write_if_missing(p, content):
    p.parent.mkdir(parents=True, exist_ok=True)
    if not p.exists(): p.write_text(content, encoding='utf-8')

def haye_template_path():
    return plugin_root()/'skills'/'init-memory'/'templates'/'HAYE.md'

def ensure_haye_template_available():
    template_path = haye_template_path()
    if template_path.exists():
        return template_path
    print('Canonical HAYE template is missing; refusing to initialize an incomplete vault.', file=sys.stderr)
    raise SystemExit(1)

def haye_template(project):
    text = ensure_haye_template_available().read_text(encoding='utf-8')
    return text.replace('<project-name>', project)

def init_config():
    p=config_path()
    if p.exists():
        load_config()
        print('.hayeos.json already exists')
        return 0
    cfg={'project':cwd().name,'memoryPath':f'./{cwd().name}_obs','sourcePath':'.','defaultWorkflow':'memory-first','sessionCloseRequired':True}
    p.write_text(json.dumps(cfg,indent=2), encoding='utf-8')
    print('created .hayeos.json')
    return 0

def init_vault():
    ensure_haye_template_available()
    cfg=load_config()
    if not cfg: init_config(); cfg=load_config()
    mp=memory_path() or (cwd()/f'{cwd().name}_obs')
    if not ensure_project_memory_target(mp): return 1
    mp.mkdir(parents=True, exist_ok=True)
    for d in DIRS: (mp/d).mkdir(parents=True, exist_ok=True); write_if_missing(mp/d/'.gitkeep','')
    project=cfg.get('project') or cwd().name
    write_if_missing(mp/'HAYE.md', haye_template(project))
    write_if_missing(mp/'index.md','# Index\n\n## Core\n- [[HAYE]]\n- [[current]]\n- [[next]]\n- [[changelog]]\n- [[health]]\n\n## Working areas\n- [[04-tasks/active-task]]\n- [[07-checklists/dependency-security-checklist]]\n- [[12-risks/dependency-risks]]\n- [[02-decisions/safe-dependency-versions]]\n')
    write_if_missing(mp/'current.md',f'# Current\n\n## Project state\n- Project: {project}\n- Source path: {cfg.get("sourcePath",".")}\n- Risk level: {cfg.get("riskLevel","medium")}\n\n## Current focus\n- TBD\n\n## Known constraints\n- Keep this file under 150 lines.\n- Prefer links to context packs instead of pasted logs.\n')
    write_if_missing(mp/'next.md','# Next\n\n## Top actions\n1. Confirm the active task.\n2. Create a context pack for non-trivial work.\n3. Run the smallest useful verification command.\n4. Update decisions or risks when dependencies/security change.\n5. Close the session with a concise handoff.\n')
    write_if_missing(mp/'changelog.md','# Changelog\n\n## Unreleased\n- Vault initialized by Haye CLI.\n')
    write_if_missing(mp/'health.md','# Health\n\n## Last check\n- Status: initialized\n- Memory lint: pending\n- Dependency audit: pending\n- React/Next security audit: pending when applicable\n')
    write_if_missing(mp/'04-tasks/active-task.md','# Active Task\n\n## Goal\nTBD\n\n## Scope\nTBD\n\n## Verification\nTBD\n')
    write_if_missing(mp/'07-checklists/dependency-security-checklist.md','# Dependency Security Checklist\n\n- [ ] `package.json` inspected from configured `sourcePath`\n- [ ] Lockfile inspected or missing lockfile documented\n- [ ] Package manager audit run or limitation documented\n- [ ] Official live advisories checked when internet is available\n- [ ] No dependency was selected only because it is `latest`\n- [ ] React/Next.js embedded baseline checked when applicable\n- [ ] Cloudflare WAF treated as defense-in-depth, not a patch replacement\n')
    write_if_missing(mp/'12-risks/dependency-risks.md','# Dependency Risks\n\n## Open risks\n- None recorded yet.\n\n## Review notes\n- Add advisory URLs, affected package names, current versions, selected patched versions and verification commands here.\n')
    write_if_missing(mp/'02-decisions/safe-dependency-versions.md','# Safe Dependency Versions\n\n## Policy\n- Prefer patched compatible versions over blind major upgrades.\n- Do not use `latest` as a version decision.\n- Use official live sources when available; document when offline.\n\n## Decisions\n- None recorded yet.\n')
    print(f'vault ready: {mp}')

def lint():
    mp=memory_path()
    if not mp: print('No memory vault found'); return 1
    issues=[]
    for f in CORE_FILES:
        if not (mp/f).exists(): issues.append(f'missing core file: {f}')
    for f in ['current.md','next.md']:
        p=mp/f
        if p.exists() and len(p.read_text(errors='ignore').splitlines())>180: issues.append(f'oversized memory file: {f}')
    raw=list((mp/'08-raw').rglob('*')) if (mp/'08-raw').exists() else []
    raws=[x for x in raw if x.is_file() and x.name!='.gitkeep']
    if raws: issues.append(f'raw files present, ensure ingested/summarized: {len(raws)}')
    if issues:
        print('Haye lint issues:'); [print('- '+i) for i in issues]; return 1
    print('Haye lint OK'); return 0

def raw_status():
    mp=memory_path();
    if not mp: print('No vault'); return
    files=[x for x in (mp/'08-raw').rglob('*') if x.is_file() and x.name!='.gitkeep'] if (mp/'08-raw').exists() else []
    print(f'raw files: {len(files)}')
    for x in files[:50]: print('-', x.relative_to(mp))

def parse_pkg():
    p=source_path()/'package.json'
    if not p.exists(): return {}
    try:
        data=json.loads(p.read_text())
    except Exception as e:
        print(f'Cannot parse package.json: {e}'); return {}
    deps={}
    for key in ['dependencies','devDependencies','peerDependencies','optionalDependencies']:
        deps.update(data.get(key,{}) or {})
    return deps

def clean(v): return re.sub(r'^[~^<>= ]+','',v or '')
def version_tuple(v):
    v=clean(v).split('-')[0]
    parts=[]
    for p in v.split('.')[:3]:
        try: parts.append(int(re.sub(r'\D.*','',p) or 0))
        except: parts.append(0)
    while len(parts)<3: parts.append(0)
    return tuple(parts)
def in_range(v, lo, hi):
    t=version_tuple(v); return version_tuple(lo)<=t<=version_tuple(hi)

def react_next_audit():
    deps=parse_pkg(); print('# React / Next.js Security Report\n')
    print(f'Source path: {source_path()}\n')
    if not deps: print('No package.json dependencies found.'); return 1
    for n in ['next','react','react-dom','react-server-dom-webpack','react-server-dom-parcel','react-server-dom-turbopack']:
        if n in deps: print(f'- {n}: {deps[n]}')
    print('\n## Findings')
    bad=False
    for pkg, spec in deps.items():
        if clean(spec).lower()=='latest':
            print(f'- UNSAFE VERSION POLICY: {pkg} uses `latest`. Choose a specific patched compatible version after checking advisories.'); bad=True
    for pkg in ['react-server-dom-webpack','react-server-dom-parcel','react-server-dom-turbopack']:
        if pkg in deps:
            v=clean(deps[pkg])
            if in_range(v,'19.0.0','19.0.5') or in_range(v,'19.1.0','19.1.6') or in_range(v,'19.2.0','19.2.5'):
                print(f'- UNSAFE: {pkg} {deps[pkg]} is in embedded vulnerable RSC range. Recommend patched compatible version 19.0.6 / 19.1.7 / 19.2.6 or later.'); bad=True
    if 'next' in deps:
        v=clean(deps['next']); t=version_tuple(v)
        if t[0]==15 and t < version_tuple('15.5.16'):
            print(f'- UNSAFE BASELINE: next {deps["next"]} below 15.5.16. Recommend 15.5.16+ compatible patch.'); bad=True
        if t[0]==16 and t < version_tuple('16.2.5'):
            print(f'- UNSAFE BASELINE: next {deps["next"]} below 16.2.5. Recommend 16.2.5+ compatible patch.'); bad=True
    if not bad: print('- No embedded React/Next vulnerable baseline detected. Run live advisory/audit check if internet is available.')
    print('\n## Cloudflare WAF status\n- WAF is defense-in-depth only. It does not replace dependency patching.\n')
    print('## Live advisory note\n- If internet is available, verify with npm registry, npm audit, GitHub advisories, React/Next/Cloudflare changelogs.\n')
    return 1 if bad else 0

def deps_audit():
    sp=source_path()
    pm='npm'
    if (sp/'pnpm-lock.yaml').exists(): pm='pnpm'
    elif (sp/'yarn.lock').exists(): pm='yarn'
    print(f'package manager guess: {pm}')
    print(f'source path: {sp}')
    if not (sp/'package.json').exists(): print('package.json missing'); return 1
    deps=parse_pkg()
    latest=[name for name, spec in deps.items() if clean(spec).lower()=='latest']
    if latest:
        print('unsafe version policy: dependencies must not use latest:', ', '.join(sorted(latest)))
    if not any((sp/x).exists() for x in ['package-lock.json','pnpm-lock.yaml','yarn.lock','bun.lockb']): print('warning: lockfile missing')
    cmd={'npm':['npm','audit'],'pnpm':['pnpm','audit'],'yarn':['yarn','npm','audit']}.get(pm,['npm','audit'])
    print('recommended audit command:', ' '.join(cmd))
    print('live advisory rule: check official sources when internet is available; if unavailable, document that only local files and embedded Haye rules were used.')
    return 1 if latest else 0

def context_pack(task='manual-task'):
    mp=memory_path();
    if not mp: print('No vault'); return 1
    filename=(re.sub(r'[^a-zA-Z0-9_-]+','-',task.strip())[:60] or 'context-pack')+'.md'
    out=mp/'09-context-packs'/filename
    if not ensure_project_memory_target(out): return 1
    write_if_missing(out, f'# Context Pack: {task}\n\n## Task\n{task}\n\n## Relevant memory files\n- HAYE.md\n- current.md\n- next.md\n\n## Relevant source files\nTBD\n\n## Risks\nTBD\n\n## First plan\nTBD\n')
    print(out)

def health():
    print('Haye health'); print('cwd:', cwd()); print('config:', config_path().exists()); print('source:', source_path()); print('vault:', memory_path())
    return lint()

def usage():
    print("""haye CLI
commands:
  init                  create .hayeos.json and vault
  init-config           create .hayeos.json
  find-vault            print memoryPath
  print-config          print config
  lint                  lint memory vault
  health                health + lint
  raw-status            list raw files
  context-pack [task]   create context pack
  deps-audit            local dependency audit helper
  react-nextjs-audit    check embedded React/Next vulnerable baselines
  dependency-report     alias deps-audit
  safe-version-check    alias react-nextjs-audit
  cloudflare-framework-report alias react-nextjs-audit
  doctor                health + deps + React/Next audit
""")

def main():
    try:
        cmd=sys.argv[1] if len(sys.argv)>1 else '--help'
        if cmd in ['--help','-h','help']: usage(); return 0
        if cmd=='init': return init_vault() or 0
        if cmd=='init-config': return init_config() or 0
        if cmd=='find-vault':
            mp = memory_path()
            if not mp:
                print('No vault')
                return 1
            print(mp)
            return 0
        if cmd=='print-config': print(json.dumps(load_config(),indent=2)); return 0
        if cmd=='lint': return lint()
        if cmd=='health': return health()
        if cmd=='raw-status': raw_status(); return 0
        if cmd=='context-pack': return context_pack(' '.join(sys.argv[2:]) or 'manual-task') or 0
        if cmd in ['deps-audit','dependency-report']: return deps_audit()
        if cmd in ['react-nextjs-audit','safe-version-check','cloudflare-framework-report']: return react_next_audit()
        if cmd=='doctor': health(); deps_audit(); return react_next_audit()
        usage(); return 1
    except ConfigError as e:
        print(e, file=sys.stderr)
        return 1
if __name__=='__main__': sys.exit(main())
